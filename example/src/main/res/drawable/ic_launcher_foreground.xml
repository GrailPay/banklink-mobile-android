<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon foreground: the GrailPay mark centered in the 108dp canvas.
    The logo is held at 60x61dp so it stays inside the ~66dp circular safe zone
    (launchers crop the foreground to a circle / squircle / etc.).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="60dp"
        android:height="61dp"
        android:gravity="center"
        android:drawable="@mipmap/grailpay_logo" />
</layer-list>
